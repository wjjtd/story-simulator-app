name: Build Kivy APK

on: [push]

jobs:
  build:
    runs-on: ubuntu-20.04
    steps:
    - uses: actions/checkout@v3
    
    - name: Setup Python
      uses: actions/setup-python@v4
      with:
        python-version: '3.8'
        
    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install Cython
        pip install buildozer
        
    - name: Prepare buildozer.spec
      run: |
        # 如果没有buildozer.spec则创建一个基础文件
        if [ ! -f buildozer.spec ]; then
          echo "[app]" > buildozer.spec
          echo "title = AI故事模拟器" >> buildozer.spec
          echo "package.name = storysimulator" >> buildozer.spec
          echo "package.domain = org.example" >> buildozer.spec
          echo "source.dir = ." >> buildozer.spec
          echo "version = 0.1" >> buildozer.spec
          echo "requirements = python3,kivy,requests" >> buildozer.spec
          echo "android.permissions = INTERNET,WRITE_EXTERNAL_STORAGE" >> buildozer.spec
          echo "android.archs = armeabi-v7a" >> buildozer.spec
          echo "android.minapi = 21" >> buildozer.spec
          echo "android.api = 27" >> buildozer.spec
        fi
        cat buildozer.spec
        
    - name: Build APK
      run: |
        # 设置环境变量
        export ANDROID_HOME=$ANDROID_SDK_ROOT
        buildozer android debug
        echo "=== Checking for APK files ==="
        find . -name "*.apk" -type f
        ls -la **/*.apk 2>/dev/null || echo "No APK files found"
        
    - name: Upload APK
      if: always()
      uses: actions/upload-artifact@v4
      with:
        name: kivy-story-simulator-apk
        path: |
          **/*.apk
        retention-days: 30
